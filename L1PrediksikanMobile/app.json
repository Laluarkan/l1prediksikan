{
  "expo": {
    "name": "L1Prediksi-Kan",
    "slug": "l1prediksi-kan",
    "scheme": "com.naufal.l1prediksikan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
