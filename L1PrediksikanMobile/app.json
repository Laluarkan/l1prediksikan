      },
      "package": "com.naufal.l1prediksikan"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3cf18af4-2f21-4830-8b4f-4043753c4ccd"
      }
    }
  }
}
